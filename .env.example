# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Daily report destination channel ID
DAILY_REPORT_CHANNEL_ID=

# Daily report time in JST. Change these for local testing.
DAILY_REPORT_HOUR=7
DAILY_REPORT_MINUTE=0

# Optional: Discord user ID whose ledger is used for scheduled reports.
# If empty, the latest user_assets row is used.
DAILY_REPORT_USER_ID=
